<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>Admin Panel</title>
  <style>
    /* Import Roboto font for a modern look */
    @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap');

    /* Global Styles */
    body {
      margin: 0;
      padding: 0;
      background: linear-gradient(135deg, #1e1e2f, #121212);
      font-family: 'Roboto', sans-serif;
      color: #e0e0e0;
    }
    header {
      text-align: center;
      padding: 40px 20px;
      background: #27293d;
      border-bottom: 2px solid #3a3f58;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
    }
    header h1 {
      margin: 0;
      font-size: 3rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #00ffd1;
      text-shadow: 0 0 10px rgba(0, 255, 209, 0.7);
    }
    main {
      max-width: 1200px;
      margin: 40px auto;
      padding: 20px;
    }
    .challenge-container {
      background: rgba(40, 40, 60, 0.8);
      border: 1px solid #3a3f58;
      border-radius: 10px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.7);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .challenge-container:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.8);
    }
    .challenge-container p {
      font-size: 1.5rem;
      margin-bottom: 15px;
      color: #e0e0e0;
    }
    .challenge-container form {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
    }
    .challenge-container form label {
      font-size: 1.5rem;
      margin-right: 10px;
      color: #00ffd1;
    }
    .challenge-container form select {
      font-size: 1.5rem;
      padding: 10px 15px;
      border: none;
      border-radius: 5px;
      background: #2a2a3d;
      color: #e0e0e0;
      margin-right: 10px;
      outline: none;
      appearance: none;
    }
    .challenge-container form button {
      font-size: 1.5rem;
      padding: 10px 20px;
      border: none;
      border-radius: 5px;
      background: linear-gradient(135deg, #00ffd1, #00b3a6);
      color: #121212;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.3s ease, transform 0.2s ease;
    }
    .challenge-container form button:hover {
      background: linear-gradient(135deg, #00b3a6, #00ffd1);
      transform: scale(1.05);
    }
    /* Custom scrollbar for a modern touch */
    ::-webkit-scrollbar {
      width: 10px;
    }
    ::-webkit-scrollbar-track {
      background: #1e1e2f;
    }
    ::-webkit-scrollbar-thumb {
      background: #3a3f58;
      border-radius: 10px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #00ffd1;
    }
  </style>
  <!-- Load jQuery (for DOM manipulation and AJAX) -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <!-- Load Socket.IO client from CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/3.1.3/socket.io.min.js"></script>
</head>
<body>
  <header>
    <h1>Pending Challenges</h1>
  </header>
  <main>
    <!-- Wrap challenges in a container to allow dynamic updating -->
    <div id="challenges-container">
      {% for challenge in challenges %}
        <div class="challenge-container">
          <p>
            {{ challenge.challenger_name }} vs {{ challenge.opponent_name }} 
            (Deadline: {{ challenge.deadline }})
          </p>
          <form method="POST" action="/submit_result">
            <input type="hidden" name="challenge_id" value="{{ challenge.id }}">
            <label for="result-{{ challenge.id }}">Result:</label>
            <select id="result-{{ challenge.id }}" name="result">
              <option value="challenger_wins">{{ challenge.challenger_name }} Wins</option>
              <option value="opponent_wins">{{ challenge.opponent_name }} Wins</option>
              <option value="not_happened">Not Happened</option>
            </select>
            <button type="submit">Submit Result</button>
          </form>
        </div>
      {% endfor %}
    </div>
  </main>

  <script>
    $(document).ready(function(){
      // Initialize Socket.IO client
      var socket = io();

      // When an update event is received, refresh the challenges container.
      socket.on("update", function(data) {
        console.log("Received update event", data);
        updateChallenges();
      });

      // Function to update the challenge list from the /admin route.
      function updateChallenges() {
        $.get("/admin", function(data){
          // Use DOMParser to extract the new challenges container.
          var parser = new DOMParser();
          var doc = parser.parseFromString(data, "text/html");
          var newContent = doc.querySelector("#challenges-container").innerHTML;
          $("#challenges-container").html(newContent);
        });
      }
    });
  </script>
</body>
</html>
