# Stecher Tennis — Environment Configuration
# Copy to .env and fill in real values before running docker compose up
#
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d

# REQUIRED: Flask session encryption key
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# 6ac874427600486aca27.................
SECRET_KEY=change-me-generate-a-real-secret

# REQUIRED: CORS allowed origins (comma-separated)
# Must match the URL users access in their browser
CORS_ALLOWED_ORIGINS=https://nechvatal.duckdns.org:10443

# Optional: Enable Flask debug mode (set false in production)
FLASK_DEBUG=false

# Optional: Override system time for testing (format: YYYY-MM-DD-HH-MM-SS)
# TEST_DATE=2025-01-15-10-00-00

# --- HTTPS / DuckDNS Configuration (Phase 3) ---

# REQUIRED: DuckDNS domain (without .duckdns.org suffix)
DUCKDNS_DOMAIN=nechvatal

# REQUIRED: DuckDNS API token for DNS-01 ACME challenge
DUCKDNS_TOKEN=your-duckdns-token-here

# REQUIRED: Email for Let's Encrypt ACME account registration
ACME_EMAIL=your-email@example.com

# REQUIRED: ACME CA directory URL (must always be set)
# Staging (for testing):    https://acme-staging-v02.api.letsencrypt.org/directory
# Production (for real certs): https://acme-v02.api.letsencrypt.org/directory
ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory

# HTTPS port (default: 10443)
HTTPS_PORT=10443

# --- Staging to Production Switchover ---
# 1. Change ACME_CA to: https://acme-v02.api.letsencrypt.org/directory
# 2. docker compose down
# 3. docker volume rm $(docker volume ls -q | grep caddy_data)
# 4. docker compose up -d
