# Exclude mobile_stecher_tennis directory except for specific parts
mobile_stecher_tennis/*
# But include the lib directory
!mobile_stecher_tennis/lib/
!mobile_stecher_tennis/lib/**
# And include files directly in mobile_stecher_tennis
!mobile_stecher_tennis/*.*
# Other exclusions
# documentation/02_app_description.txt
# aider-specific files
.aider*
.aider.conf.yml
# Exclude backup
.env
backup/*
backups/
SESSION_CHECKPOINT.md
__pycache__/
*.db


# Player/admin login handouts (contain credentials — keep out of git)
spieler*.txt

# Local DB backup copies (real player data — *.db above misses the .db.<suffix> variants)
tennis.db.*

# Security review artifacts (list unfixed findings — keep out of the public repo)
REVIEW*.md

# Root logo source (duplicate of the served static/02_tennislogo.png — no need to track)
/02_tennislogo.png
