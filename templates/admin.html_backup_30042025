<body>
  <header>
    <h1>Ausstehende Herausforderungen</h1>
  </header>
  <main>
    <div id="challenges-container">
      {% for challenge in challenges %}
        <div class="challenge-container" data-challenge-id="{{ challenge.id }}" data-challenger-id="{{ challenge.challenger_id }}" data-opponent-id="{{ challenge.opponent_id }}">
          <p>
            <span class="challenger-name">{{ challenge.challenger_name }}</span> gegen <span class="opponent-name">{{ challenge.opponent_name }}</span>
            (Frist: {{ challenge.deadline.strftime('%Y-%m-%d %H:%M') if challenge.deadline else 'N/A' }}) {# Format deadline #}
          </p>
          <form class="result-form" method="POST" action="/submit_result">
            <input type="hidden" name="challenge_id" value="{{ challenge.id }}">

            <!-- *** Result Dropdown *** -->
            <div class="result-dropdown-section">
                <label for="result-{{ challenge.id }}">Sieger:</label>
                <select id="result-{{ challenge.id }}" name="result" class="result-select">
                  <option value="">-- Bitte wählen --</option> {# Add default option #}
                  <option class="option-challenger-wins" value="challenger_wins">{{ challenge.challenger_name }} gewinnt</option>
                  <option class="option-opponent-wins" value="opponent_wins">{{ challenge.opponent_name }} gewinnt</option>
                  <option class="option-not-happened" value="not_happened">Nicht stattgefunden</option>
                </select>
            </div>

            <!-- *** Wrapper for details, hidden initially *** -->
            <div class="result-details-wrapper" style="display: none;">

                <!-- Score Inputs -->
                <div class="score-input-section">
                     <label class="score-label">Endergebnis:</label>
                     <input type="text" name="set1_score" class="score-input" placeholder="Satz 1: z.B. 6:4" aria-label="Satz 1 Ergebnis">
                     <input type="text" name="set2_score" class="score-input" placeholder="Satz 2: z.B. 7:6(8:6)" aria-label="Satz 2 Ergebnis">
                     <input type="text" name="set3_score" class="score-input" placeholder="Satz 3: z.B. 10:8" aria-label="Satz 3 Ergebnis">
                </div>

                <!-- Special Result Input (Dropdown) -->
                 <div class="special-result-section">
                    <label for="special_result-{{ challenge.id }}">Sonderfall:</label>
                    <select id="special_result-{{ challenge.id }}" name="special_result" class="special-result-select">
                        <option value="">-- Kein Sonderfall --</option>
                        <option value="Aufgabe">Aufgabe</option>
                        <option value="Disqualifikation">Disqualifikation</option>
                    </select>
                </div>

                <!-- Score Display Area -->
                <div id="score-display-{{ challenge.id }}" class="score-display-section">
                    <!-- Score preview appears here -->
                </div>

                <!-- Submit Button -->
                <div class="submit-button-section">
                    <button type="submit" class="submit-button" disabled>Ergebnis absenden</button>
                </div>

            </div> <!-- *** END: result-details-wrapper *** -->

          </form>
        </div>
      {% endfor %}

      {% if not challenges %}
        <div class="no-challenges">
          Derzeit keine ausstehenden Herausforderungen.
        </div>
      {% endif %}
    </div>
  </main>

  <script>
    $(document).ready(function(){
      const socket = io({
        reconnectionAttempts: 5, reconnectionDelay: 1000, timeout: 10000
      });
      const $challengesContainer = $("#challenges-container");

      // Regex for allowed characters in score input
      const allowedScoreCharsRegex = /[^0-9:() ]/g; // Finds all NOT allowed characters
      // Regex to check if a score looks potentially valid for confirmation
      const validScoreFormatRegex = /^\d+:\d+(\(\d+:\d+\))?$/;
      // Key for storing the reset timer ID on the form element
      const formTimeoutKey = 'resetTimerId';
      // Timeout duration in milliseconds (2 minutes)
      const resetTimeoutDuration = 120 * 1000;

      // --- Function to clear localStorage colors (not directly related to button state) ---
      function clearResolvedChallengeColors(challengeId, challengerId, opponentId) {
        // ... (implementation remains the same)
      }

      // --- Function to update the list of challenges from the server ---
      function updateChallenges() {
        // Clear existing reset timers before updating content
        $('.result-form').each(function() {
            const $form = $(this);
            const timerId = $form.data(formTimeoutKey);
            if (timerId) {
                clearTimeout(timerId);
                $form.removeData(formTimeoutKey);
                console.log(`Cleared reset timer for form related to challenge ID: ${$form.find('input[name="challenge_id"]').val()} during update.`);
            }
        });

        $.get("/admin", function(data){ // Fetch the admin page HTML
          try {
            const parser = new DOMParser();
            const doc = parser.parseFromString(data, "text/html");
            const newContent = doc.querySelector("#challenges-container").innerHTML;
            $challengesContainer.html(newContent); // Replace the content
            add3DEffects(); // Re-apply 3D effects if any
            bindInputListeners(); // Re-bind listeners to new elements

            // Ensure button state AND visibility state are set after update for all forms
            $('#challenges-container .result-form').each(function() {
                const $form = $(this);
                const $resultSelect = $form.find('.result-select');
                if ($resultSelect.length) {
                    handleInputChange({ target: $resultSelect[0] }); // Trigger state update
                } else {
                     console.warn("Could not find .result-select to initialize state for an updated form.");
                }
            });

          } catch (error) { console.error("Error updating challenges:", error); } // English comment
        });
      }

      // --- Function to add 3D effects (if applicable based on CSS) ---
      function add3DEffects() {
        $(".challenge-container").each(function(index) {
          if (window.getComputedStyle(document.body).perspective !== 'none') {
            $(this).css({'transition-delay': `${index * 0.1}s`, 'transform': `translateZ(${10 + index * 2}px)`});
          } else {
            $(this).css({'transition-delay': '', 'transform': ''});
          }
        });
      }

      // --- Function to sanitize score input, removing disallowed characters ---
      function sanitizeScoreInput(event) {
          const input = event.target;
          const originalValue = input.value;
          const sanitizedValue = originalValue.replace(allowedScoreCharsRegex, '');

          if (originalValue !== sanitizedValue) {
              let start = input.selectionStart;
              let end = input.selectionEnd;
              const diff = originalValue.length - sanitizedValue.length;
              input.value = sanitizedValue;
              // Adjust cursor position after sanitization
              input.setSelectionRange(Math.max(0, start - diff), Math.max(0, end - diff));
          }
          // Validation/confirmation happens on blur or change
      }

      // --- Function to handle score input confirmation on blur ---
      function handleScoreInputBlur(event) {
          const input = event.target;
          const $input = $(input);
          const currentValue = input.value.trim();
          const lastConfirmedValue = $input.data('confirmed-value') || '';

          // Only confirm if the value is potentially valid, non-empty, and different from last confirmed
          if (currentValue && currentValue !== lastConfirmedValue && validScoreFormatRegex.test(currentValue)) {
              let setName = '';
              if (input.name === 'set1_score') setName = 'Satz 1';
              else if (input.name === 'set2_score') setName = 'Satz 2';
              else if (input.name === 'set3_score') setName = 'Satz 3';

              // German confirmation message
              const confirmationMessage = `Bitte bestätige, dass ${setName} mit ${currentValue} beendet wurde.`;

              if (confirm(confirmationMessage)) {
                  $input.data('confirmed-value', currentValue); // Store confirmed value
              } else {
                  input.value = ''; // Clear input if user cancels
                  $input.removeData('confirmed-value'); // Remove confirmation status
              }
          } else if (!currentValue || !validScoreFormatRegex.test(currentValue)) {
              // If the value becomes empty or invalid after being confirmed, remove confirmation
              $input.removeData('confirmed-value');
          }
          // Always trigger the main input handler after blur to re-evaluate form state
          handleInputChange(event);
      }

      // --- Function to reset a specific form ---
      function resetForm($form) {
          if (!$form || !$form.length) return;

          const challengeId = $form.find('input[name="challenge_id"]').val();
          console.log(`Resetting form for challenge ID: ${challengeId} due to inactivity.`);

          // Reset dropdowns
          $form.find('.result-select').val('');
          // $form.find('.special-result-select').val(''); // This will be handled by handleInputChange

          // Clear score inputs and their confirmed values
          // $form.find('.score-input').each(function() { // This will be handled by handleInputChange
          //     $(this).val('').removeData('confirmed-value');
          // });

          // Clear the score display
          // $form.find('.score-display-section').text('...').removeClass('score-error'); // Handled by handleInputChange

          // Disable the submit button explicitly
          // $form.find('.submit-button').prop('disabled', true); // Handled by handleInputChange

          // Hide the details wrapper
          // $form.find('.result-details-wrapper').slideUp(); // Handled by handleInputChange

          // Clear the timer data from the form element
          $form.removeData(formTimeoutKey);

          // Trigger handleInputChange to reset everything based on the empty result select
          handleInputChange({ target: $form.find('.result-select')[0] });


          // Optional: Add a visual cue that the form was reset
          const $container = $form.closest('.challenge-container');
          if ($container.length) {
              $container.css('background-color', '#fff3cd'); // Light yellow flash
              setTimeout(() => { $container.css('background-color', 'var(--container-bg)'); }, 1500);
          }
      }


      // --- Function to handle input changes and update button state/score display ---
      function handleInputChange(event) {
          const $form = $(event.target).closest('form.result-form');
          if (!$form.length) return;

          const $submitButton = $form.find('.submit-button');
          const $scoreDisplay = $form.find('.score-display-section');
          const $resultSelect = $form.find('.result-select');
          const selectedResult = $resultSelect.val();
          const $detailsWrapper = $form.find('.result-details-wrapper');
          const $scoreInputs = $form.find('.score-input');
          const $specialResultSelect = $form.find('.special-result-select');

          // --- MODIFIED: Show/Hide Logic for Details ---
          // Show details if ANY result is selected (winner or not happened)
          if (selectedResult) {
              $detailsWrapper.slideDown(200);
          } else {
              $detailsWrapper.slideUp(200);
          }

          // --- NEW: Disable/Enable Inputs based on "Nicht stattgefunden" ---
          if (selectedResult === "not_happened") {
              // Disable score inputs and special result dropdown
              $scoreInputs.prop('disabled', true).val(''); // Disable and clear value
              $specialResultSelect.prop('disabled', true).val(''); // Disable and clear value
              // Clear any confirmation data as well
              $scoreInputs.removeData('confirmed-value');
          } else {
              // Enable score inputs and special result dropdown if a winner is selected or no selection
              $scoreInputs.prop('disabled', false);
              $specialResultSelect.prop('disabled', false);
              // Note: Values are not restored here, they remain as they were or empty
          }

          // --- Score Validation and Display Logic ---
          const s1Input = $form.find('input[name="set1_score"]'); // Re-select in case they were just enabled/disabled
          const s2Input = $form.find('input[name="set2_score"]');
          const s3Input = $form.find('input[name="set3_score"]');
          const s1 = s1Input.val().trim();
          const s2 = s2Input.val().trim();
          const s3 = s3Input.val().trim();
          const specialResult = $specialResultSelect.val(); // Use the re-selected element

          let displayScore = "";
          let scoreIsValid = false;
          let requiresConfirmation = false; // Flag if any score needs confirmation
          $scoreDisplay.removeClass('score-error');

          // --- MODIFIED: Handle "Nicht stattgefunden" display ---
          if (selectedResult === "not_happened") {
              displayScore = "Nicht stattgefunden"; // German text
              scoreIsValid = true; // Mark as valid for enabling the button
          } else if (specialResult === "Aufgabe" || specialResult === "Disqualifikation") {
              displayScore = specialResult; // German text
              scoreIsValid = true;
              $scoreDisplay.addClass('score-error'); // Use error color for special results
          } else if (s1 || s2 || s3) { // Only validate if at least one score is entered AND not "Nicht stattgefunden"
              const s1Valid = !s1 || validScoreFormatRegex.test(s1);
              const s2Valid = !s2 || validScoreFormatRegex.test(s2);
              const s3Valid = !s3 || validScoreFormatRegex.test(s3);

              // Check confirmation status
              const s1Confirmed = !s1 || s1Input.data('confirmed-value') === s1;
              const s2Confirmed = !s2 || s2Input.data('confirmed-value') === s2;
              const s3Confirmed = !s3 || s3Input.data('confirmed-value') === s3;

              if (s1Valid && s2Valid && s3Valid) {
                  // Basic structure check: Need at least set 1 and set 2
                  if (s1 && s2) {
                      let sets = [s1, s2];
                      if (s3) { sets.push(s3); }
                      displayScore = sets.join(' ');
                      // Score structure is valid, now check confirmation
                      if (s1Confirmed && s2Confirmed && s3Confirmed) {
                          scoreIsValid = true;
                      } else {
                          displayScore += " (Bestätigung ausstehend)"; // German text
                          requiresConfirmation = true; // Indicate confirmation is needed
                          scoreIsValid = false; // Not fully valid until confirmed
                      }
                  } else if (s1 && !s2 && !s3) { // Only S1 entered
                      displayScore = s1 + " (Satz 2 fehlt)"; // German text
                      scoreIsValid = false;
                      if (!s1Confirmed) requiresConfirmation = true;
                  } else { // Other invalid combinations (e.g., only S2)
                      displayScore = "Unvollständig"; // German text
                      scoreIsValid = false;
                      if ((s1 && !s1Confirmed) || (s2 && !s2Confirmed) || (s3 && !s3Confirmed)) requiresConfirmation = true;
                  }
              } else {
                  displayScore = "Ungültiges Format"; // German text
                  scoreIsValid = false;
                  $scoreDisplay.addClass('score-error');
              }
          } else {
              // No scores entered, no special result, and not "Nicht stattgefunden"
              displayScore = "..."; // Placeholder
              scoreIsValid = false;
          }
          $scoreDisplay.text(displayScore);

          // --- Button Enable/Disable Logic ---
          let enableButton = false;
          if (selectedResult === "not_happened") {
              enableButton = true; // Directly enable if "Nicht stattgefunden"
              // Score display is already set above
              $scoreDisplay.removeClass('score-error');
          } else if (selectedResult === "challenger_wins" || selectedResult === "opponent_wins") {
              // Enable only if score is valid (structure AND confirmation) OR special result selected
              if (scoreIsValid && !requiresConfirmation) {
                  enableButton = true;
              }
          }
          // If no result is selected ("-- Bitte wählen --"), enableButton remains false.
          $submitButton.prop('disabled', !enableButton);

          // --- Timer Management Logic ---
          let currentTimerId = $form.data(formTimeoutKey);
          // Start or reset timer only if the button is enabled (meaning valid input exists)
          if (enableButton) {
              if (currentTimerId) {
                  clearTimeout(currentTimerId); // Clear existing timer
              }
              // Set a new timer
              const newTimerId = setTimeout(() => {
                  resetForm($form);
              }, resetTimeoutDuration);
              $form.data(formTimeoutKey, newTimerId); // Store the new timer ID
          } else {
              // If the button becomes disabled, clear any active timer
              if (currentTimerId) {
                  clearTimeout(currentTimerId);
                  $form.removeData(formTimeoutKey); // Remove timer ID reference
              }
          }
      }


      // --- Bind event listeners to form controls ---
      function bindInputListeners() {
          const scoreInputSelector = '.result-form .score-input';
          const otherControlsSelector = '.result-form .result-select, .result-form .special-result-select';

          // Use event delegation on the container
          $challengesContainer.off('input', scoreInputSelector) // Remove previous listeners first
                             .on('input', scoreInputSelector, sanitizeScoreInput);

          $challengesContainer.off('blur', scoreInputSelector)
                             .on('blur', scoreInputSelector, handleScoreInputBlur); // Use blur for confirmation

          $challengesContainer.off('change', otherControlsSelector)
                             .on('change', otherControlsSelector, handleInputChange); // Use change for dropdowns
      }


      // --- Socket.IO event handlers ---
      socket.on("connect", function() {
          console.log("Connected to server via Socket.IO");
          updateChallenges(); // Fetch initial/updated challenges on connect
      });
      socket.on("update", function(data) {
          console.log("Received 'update' event from server", data);
          updateChallenges(); // Refresh challenge list when server sends update
      });
      socket.on("connect_error", function(error) {
          console.error("Socket.IO connection error:", error);
      });
      socket.on("disconnect", function(reason) {
          console.log("Disconnected from server:", reason);
      });

      // --- Form submission handler using event delegation ---
      $challengesContainer.on("submit", ".result-form", function(e) {
        e.preventDefault(); // Prevent default form submission
        const $form = $(this);
        const $container = $form.closest(".challenge-container");
        const $button = $form.find('.submit-button');

        // Double-check if button is enabled before proceeding
        if ($button.prop('disabled')) {
            console.warn("Submit attempted while button was disabled.");
            // Optionally re-run validation in case state is inconsistent
            handleInputChange({ target: $form.find('.result-select')[0] });
            return; // Stop submission
        }

        // Clear the inactivity reset timer for this form
        const timerId = $form.data(formTimeoutKey);
        if (timerId) {
            clearTimeout(timerId);
            $form.removeData(formTimeoutKey);
            console.log(`Cleared reset timer ${timerId} on form submit.`);
        }

        // Use setTimeout to ensure any pending blur events (like score confirmation) complete
        // before we serialize the form and submit.
        setTimeout(() => {
            // Re-check button state *inside* the timeout, as a blur handler might have disabled it
            if ($button.prop('disabled')) {
                 console.warn("Submit cancelled: button became disabled after blur event.");
                 // If it became disabled (e.g., user cancelled confirm), re-enable timer logic if needed
                 handleInputChange({ target: $form.find('.result-select')[0] });
                 return;
            }

            // Visually indicate submission and prevent double-clicks
            $container.css('opacity', '0.7');
            $button.prop('disabled', true).text('Sende...'); // German text

            const formData = $form.serialize(); // Get data *after* potential blur changes
            const challengeId = $container.data("challenge-id");
            const challengerId = $container.data("challenger-id");
            const opponentId = $container.data("opponent-id");

            // AJAX POST request to the server
            $.post("/submit_result", formData)
              .done(function(response) {
                console.log("Submit successful (client-side). Waiting for server update/redirect.");
                // Don't manually remove the element here.
                // The server should trigger a socket.io 'update' event which calls updateChallenges()
                // This ensures the list is refreshed correctly based on server state.
              })
              .fail(function(xhr, status, error) {
                console.error("Error submitting result:", error, xhr.responseText); // English comment
                // Restore UI on failure
                $container.css({'opacity': '1', 'background-color': '#ffe6e6'}); // Indicate error visually
                setTimeout(function() { $container.css('background-color', 'var(--container-bg)'); }, 2000); // Reset background
                // Re-enable button ONLY on failure
                $button.prop('disabled', false).text('Ergebnis absenden'); // German text
                // Re-run validation which will also restart timer if applicable
                handleInputChange({ target: $form.find('.result-select')[0] });
              });
        }, 50); // Small delay (e.g., 50ms) is usually sufficient for blur events

    });
    // --- END Form submission handler ---


      // --- Initial setup when the page loads ---
      add3DEffects(); // Apply initial visual effects
      bindInputListeners(); // Set up event handling for form inputs

      // Ensure initial button state AND visibility are set correctly for all forms on load
      $('.result-form').each(function() {
          const $form = $(this);
          const $resultSelect = $form.find('.result-select');
          if ($resultSelect.length) {
              // Trigger the handler using the result select element to set initial state
              handleInputChange({ target: $resultSelect[0] });
          } else {
              console.warn("Could not find .result-select to initialize state for a form on page load.");
          }
      });

      // Fallback polling mechanism (currently commented out, Socket.IO is preferred)
      // setInterval(updateChallenges, 120000); // Update every 2 minutes as a backup
    });
  </script>
